<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Multivio Activation Email</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style type="text/css">
      /* Base */
      body {
        margin: 0;
        padding: 0;
        min-width: 100%;
        font-family: Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        background-color: #fafafa;
        color: #222222;
      }

      a {
        color: #000;
        text-decoration: none;
      }

      h1 {
        font-size: 24px;
        font-w
      }

      .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }

      .email-header {
        background-color: #0070f3;
        color: white;
        padding: 24px;
        text-align: center;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
      }

      .email-body {
        background-color: #ffffff;
        padding: 24px;
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
      }

      h1 {
        margin: 0;
        font-size: 24px;
      }

      p {
        margin-top: 0;
        margin-bottom: 16px;
        line-height: 1.5;
      }

      .button {
        display: inline-block;
        background-color: #0070f3;
        color: #ffffff;
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 4px;
        margin: 20px 0;
      }

      h2 {
        font-size: 32px;
        color: #0070f3;
        text-align: center;
      }

      .email-footer {
        margin-top: 24px;
        font-size: 14px;
        color: #777;
        text-align: center;
      }

      a {
        color: #0070f3;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-header">
        <h1>Welcome to Eshop</h1>
      </div>

      <div class="email-body">
        <p>Hello <%= userName || name %>,</p>

        <% if (activationLink) { %>
        <p>
          Thank you for signing up! Please click the button below to activate
          your account:
        </p>
        <p style="text-align: center">
          <a href="<%= activationLink %>" class="button">Activate Account</a>
        </p>
        <% } else if (otp) { %>
        <p>
          Thank you for registering with Eshop. To activate your account, please
          use the following activation code:
        </p>
        <h2><%= otp %></h2>
        <p>
          Please enter this code on the activation page within the next 5
          minutes.
        </p>
        <% } %>

        <p>If you did not create an account, no further action is required.</p>
      </div>

      <div class="email-footer">
        <p>
          If you have any questions, contact us at
          <a href="mailto:support@becodemy.com">support@becodemy.com</a>
        </p>
      </div>
    </div>
  </body>
</html>
